# Frontend environment (copy to .env.local as needed)

# Same-origin API path (recommended for local dev — proxied to Express in next.config.ts).
NEXT_PUBLIC_API_BASE_URL=/api

# Optional: backend origin used by Next.js rewrites when API base is relative.
# BACKEND_URL=http://localhost:5000

# Or point directly at the API (cross-origin; cookies need HTTPS + SameSite=None in prod):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Content Security Policy
# Enforce by default (set in next.config.ts). Uncomment to observe only:
# CSP_REPORT_ONLY=true
# In production HTTPS, optionally force HTTPS upgrades:
# CSP_UPGRADE_INSECURE_REQUESTS=true
