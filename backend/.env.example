NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=dms_db

# JWT — use long random strings in production
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session lifetime (days)
SESSION_TRUSTED_DAYS=30
SESSION_DEFAULT_DAYS=7

# Two-factor authentication
TWO_FACTOR_EXPIRES_MINUTES=10
TWO_FACTOR_RESEND_COOLDOWN=60

# SMTP (2FA emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com

# Development: print OTP in backend terminal instead of sending email
TWO_FACTOR_DEV_LOG_CODE=true
