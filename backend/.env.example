NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=dms_db

# JWT — use long random strings in production
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session lifetime (days)
SESSION_TRUSTED_DAYS=30
SESSION_DEFAULT_DAYS=7

# Two-factor authentication
TWO_FACTOR_EXPIRES_MINUTES=10
TWO_FACTOR_RESEND_COOLDOWN=60

# SMTP (2FA + invoice emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=no-reply@custodian.local

# Set true to log OTP in terminal instead of sending email (local dev only)
TWO_FACTOR_DEV_LOG_CODE=false

# Document storage — absolute path (batch scan PDFs)
FILE_SERVER=D:/DMS/fileserver

# Subpoena_Extraction Python service
SUBPOENA_EXTRACTION_API_URL=http://10.103.0.91:8010/process
SUBPOENA_EXTRACTION_TIMEOUT_MS=300000
UPLOAD_MAX_FILE_SIZE_MB=50

# Invoice automatic reminders (days between R1/R2/R3; job poll interval in ms)
INVOICE_REMINDER_INTERVAL_DAYS=5
INVOICE_REMINDER_CHECK_INTERVAL_MS=3600000

# Stripe online payments (use test keys in development; switch to live keys in production)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd
