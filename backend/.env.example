NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dms_db_dev

# Or single connection string (encode @ in password as %40)
# DATABASE_URL=mysql://root:password%40123@127.0.0.1:3306/dms_db_dev

# Auth (configure when ready)
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000

# Document storage — absolute path on the server (batch scans, orders, facilities, etc.)
FILE_SERVER=D:/DMS/fileserver

# Subpoena_Extraction Python service (unchanged — backend calls this via HTTP)
SUBPOENA_EXTRACTION_API_URL=http://10.103.0.91:8010/process
SUBPOENA_EXTRACTION_TIMEOUT_MS=300000

# Upload limit for PDF batch scan (megabytes)
UPLOAD_MAX_FILE_SIZE_MB=50
